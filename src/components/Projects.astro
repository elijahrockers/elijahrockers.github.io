---
const projects = [
  {
    title: "DICOM PHI Screening Agent",
    description:
      "Two-layer DICOM PHI detection: header tag analysis against HIPAA Safe Harbor plus OCR-based pixel inspection with Claude classification.",
    tags: ["Python", "pydicom", "pytesseract", "Claude API", "FastAPI"],
  },
  {
    title: "Clinical Text-to-SQL Agent",
    description:
      "Natural language to SQL over OMOP CDM clinical data with iterative refinement, built for Epic Clarity/Caboodle workflows.",
    tags: ["Python", "Claude API", "OMOP CDM", "SQLite", "Streamlit"],
  },
  {
    title: "CT-Based Sarcopenia Quantification",
    description:
      "Automated skeletal muscle segmentation and quantification from CT imaging. Patent pending.",
    tags: ["Python", "Machine Learning", "Docker", "Medical Imaging"],
  },
  {
    title: "PHI Scrubbing & Tokenization",
    description:
      "Automated PHI scrubbing and tokenization for multi-site clinical research, ensuring HIPAA compliance across institutions.",
    tags: ["Python", "PHI Compliance", "HIPAA", "Data Engineering"],
  },
  {
    title: "ECG Image Processing",
    description:
      "Scalable workflows for rasterized and vectorized ECG image analysis supporting large-scale cardiac research.",
    tags: ["Python", "Computer Vision", "ECG", "Medical Imaging"],
  },
  {
    title: "REDCap & XNAT Enterprise Scaling",
    description:
      "Scaled REDCap and XNAT to enterprise-wide platforms supporting 50+ investigators with 21 CFR Part 11 compliance.",
    tags: ["REDCap", "XNAT", "Infrastructure", "Compliance", "Linux"],
  },
];
---

<section id="projects" class="py-20 px-4 sm:px-6">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-2xl font-bold text-slate-900 dark:text-slate-100 mb-8 max-w-4xl mx-auto">Projects</h2>
    <div class="overflow-x-auto snap-x snap-mandatory projects-scroll">
      <div class="flex gap-6 pb-4">
        {projects.map((project) => (
          <div class="w-[85vw] sm:w-[300px] shrink-0 snap-start bg-white dark:bg-slate-800 rounded-lg border border-slate-200 dark:border-slate-700 p-6 hover:shadow-md transition-shadow">
            <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100 mb-2">{project.title}</h3>
            <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed mb-4">{project.description}</p>
            <div class="flex flex-wrap gap-2">
              {project.tags.map((tag) => (
                <span class="px-2 py-1 bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300 text-xs rounded-md font-medium">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .projects-scroll {
    scrollbar-width: thin;
    scrollbar-color: var(--color-slate-400) transparent;
  }

  .projects-scroll::-webkit-scrollbar {
    height: 12px;
  }

  .projects-scroll::-webkit-scrollbar-track {
    background: transparent;
  }

  .projects-scroll::-webkit-scrollbar-thumb {
    background-color: var(--color-slate-400);
    border-radius: 3px;
  }

  :global(.dark) .projects-scroll {
    scrollbar-color: var(--color-slate-600) transparent;
  }

  :global(.dark) .projects-scroll::-webkit-scrollbar-thumb {
    background-color: var(--color-slate-600);
  }
</style>
